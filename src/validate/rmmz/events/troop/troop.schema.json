{
  "type": "object",
  "required": ["id", "name", "members", "pages"],
  "properties": {
    "id": { "type": "integer", "minimum": 0 },
    "name": { "type": "string" },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["enemyId", "x", "y", "hidden"],
        "properties": {
          "enemyId": { "type": "integer" },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "hidden": { "type": "boolean" }
        }
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",

        "additionalProperties": true,
        "required": ["conditions", "span"],
        "properties": {
          "conditions": {
            "type": "object",
            "required": [
              "actorHp",
              "actorId",
              "actorValid",

              "enemyValid",
              "enemyIndex",
              "enemyHp",

              "switchValid",
              "switchId",

              "turnEnding",
              "turnValid"
            ],
            "properties": {
              "actorValid": { "type": "boolean" },
              "actorHp": { "type": "integer", "minimum": 0 },
              "actorId": { "type": "integer", "minimum": 0 },
              "enemyValid": { "type": "boolean" },
              "enemyIndex": { "type": "integer", "minimum": 0 },
              "enemyHp": { "type": "integer", "minimum": 0 },
              "switchValid": { "type": "boolean" },
              "switchId": { "type": "integer", "minimum": 0 },
              "turnEnding": { "type": "boolean" },
              "turnValid": { "type": "boolean" }
            }
          },
          "list": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code", "indent", "parameters"],
              "properties": {
                "code": { "type": "integer" },
                "indent": { "type": "integer" },
                "parameters": { "type": "array" }
              }
            }
          },
          "span": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
